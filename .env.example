# --- TriageBot · variables de entorno ---
# Copia este archivo a .env y rellena los valores.
# .env NUNCA se commitea (debe estar en .gitignore).

# API key de OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Modelo a usar (formato proveedor/modelo de OpenRouter)
CLASSIFIER_MODEL=openai/gpt-oss-120b

# Prompt del sistema para el clasificador
CLASSIFIER_PROMPT=Devuelve EXCLUSIVAMENTE un objeto JSON válido. Sin markdown, sin saludos, sin texto antes ni después. Los valores permitidos son: category ∈ {bug, feature_request, question, urgent}, priority ∈ {P1, P2, P3}. No inventes categorías. Máximo 5 tags. Ejemplo de respuesta válida: {"category": "bug", "priority": "P2", "tags": ["login", "crash"]}
